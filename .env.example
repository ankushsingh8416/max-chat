# --- WordPress source site --------------------------------------------------
WP_BASE_URL=https://maxestates.in

# --- OpenAI -----------------------------------------------------------
# https://platform.openai.com/api-keys
OPENAI_API_KEY=
# Optional: comma-separated additional keys for automatic failover when one
# hits a quota/rate limit or is invalid (see lib/openai/key-pool.ts). If set,
# OPENAI_API_KEY is folded into this pool too — you don't need to repeat it.
OPENAI_API_KEYS=
# Optional override, defaults to gpt-5.4-mini
OPENAI_CHAT_MODEL=gpt-5.4-mini

# --- Database --------------------------------------------------------------
# Standard Postgres connection string, e.g.
# postgres://user:password@host:5432/dbname — works against AWS RDS, a
# self-hosted Postgres box, or any other provider with the `vector` extension
# available (see sql/schema.sql). Run sql/schema.sql once against it before
# first use.
DATABASE_URL=
# Set to "disable" only for a local Postgres without TLS; managed Postgres
# (AWS RDS, etc.) needs TLS, which is enabled by default.
# DATABASE_SSL=disable

# --- Admin "upload & train" page (/admin) -----------------------------------
# Gates the drag-and-drop document upload page that adds content to the
# knowledge base outside of the WordPress sync. Pick a long random value.
ADMIN_PASSWORD=

# --- Cron / sync protection ---------------------------------------------
# Any long random string. Vercel automatically sends this as
# `Authorization: Bearer <CRON_SECRET>` when it triggers scheduled Cron Jobs
# (see vercel.json), so the /api/sync route can verify the request is legit.
# Also required to manually trigger a sync via curl.
CRON_SECRET=

# Cron expression for the in-process auto-sync scheduler (lib/scheduler.ts) —
# only relevant on a long-running server deployment (AWS EC2/ECS/Docker via
# `next start`), not serverless hosting. Defaults to once daily at 3 AM if unset.
# AUTO_SYNC_CRON_SCHEDULE=0 3 * * *

# --- Sync pipeline tuning (see lib/sync/, lib/constants.ts) ---------------
# How many embedding requests may be in flight at once. Keep at 1 unless
# you've confirmed your OpenAI tier can handle concurrent embedding calls.
EMBEDDING_CONCURRENCY=1
# Minimum milliseconds between the start of one embedding request and the next.
EMBEDDING_DELAY_MS=4500
# Texts per embeddings call. Larger batches use fewer requests against
# OpenAI's per-minute request-count limit — helpful for large syncs.
EMBEDDING_BATCH_SIZE=20
# Retries per embedding request on 429/500/503 before giving up on that page.
MAX_EMBED_RETRIES=5
# Ceiling for calculated backoff between retries (OpenAI's own Retry-After
# header, when present, is used instead and is not capped by this).
MAX_BACKOFF_MS=30000
# Local resume checkpoint path (CLI only — see lib/sync/checkpoint.ts).
CHECKPOINT_FILE=.sync-checkpoint.json

# Chat-time query embedding retry budget — deliberately much smaller than the
# bulk sync's above, so a live chat request fails fast (~1-2s) instead of
# waiting out a long backoff. A billing/plan quota error is never retried at
# all regardless of these values (see lib/sync/retry.ts).
CHAT_EMBED_MAX_RETRIES=1
CHAT_EMBED_MAX_BACKOFF_MS=1500
