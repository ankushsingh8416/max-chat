# --- WordPress source site --------------------------------------------------
WP_BASE_URL=https://maxestates.in

# --- Google Gemini -----------------------------------------------------------
# https://aistudio.google.com/app/apikey
GEMINI_API_KEY=
# Optional: comma-separated additional keys for automatic failover when one
# hits a quota/rate limit or is invalid (see lib/gemini/key-pool.ts). If set,
# GEMINI_API_KEY is folded into this pool too — you don't need to repeat it.
GEMINI_API_KEYS=
# Optional override, defaults to gemini-2.5-flash
GEMINI_CHAT_MODEL=gemini-2.5-flash

# --- Supabase ------------------------------------------------------------
# Project Settings -> API. The anon key is safe to expose to the client
# (NEXT_PUBLIC_*); the service role key must NEVER be exposed client-side —
# it is used only in server-only code (sync pipeline, analytics logging).
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- Cron / sync protection ---------------------------------------------
# Any long random string. Vercel automatically sends this as
# `Authorization: Bearer <CRON_SECRET>` when it triggers scheduled Cron Jobs
# (see vercel.json), so the /api/sync route can verify the request is legit.
CRON_SECRET=

# --- Sync pipeline tuning (see lib/sync/, lib/constants.ts) ---------------
# How many embedding requests may be in flight at once. Keep at 1 unless
# you've confirmed your Gemini tier can handle concurrent embedding calls.
EMBEDDING_CONCURRENCY=1
# Minimum milliseconds between the start of one embedding request and the next.
EMBEDDING_DELAY_MS=4500
# Texts per embedContent call. Larger batches use fewer requests against
# Gemini's daily request-count quota — the binding constraint for large syncs.
EMBEDDING_BATCH_SIZE=20
# Retries per embedding request on 429/500/503 before giving up on that page.
MAX_EMBED_RETRIES=5
# Ceiling for calculated backoff between retries (Google's own retryDelay,
# when present in the error, is used instead and is not capped by this).
MAX_BACKOFF_MS=30000
# Local resume checkpoint path (CLI only — see lib/sync/checkpoint.ts).
CHECKPOINT_FILE=.sync-checkpoint.json

# Chat-time query embedding retry budget — deliberately much smaller than the
# bulk sync's above, so a live chat request fails fast (~1-2s) instead of
# waiting out a minutes-long Gemini quota backoff. Daily-quota errors are
# never retried at all regardless of these values (see lib/sync/retry.ts).
CHAT_EMBED_MAX_RETRIES=1
CHAT_EMBED_MAX_BACKOFF_MS=1500
